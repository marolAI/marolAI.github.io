{
    "root": true,
    "env": {
        "browser": true,
        "es2021": true
    },
    "globals": {
        "$": "readonly",
        "jQuery": "readonly"
    },
    "extends": [
        "eslint:recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^_"
            }
        ],
        "no-console": "off"
    }
}